// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id          Int     @id @default(1)
  name        String
  title       String
  tagline     String
  openToWork  Boolean @default(true)
  email       String?
  linkedinUrl String?
  githubUrl   String?
}

model About {
  id  Int    @id @default(1)
  bio String @db.Text
}

enum ProjectStatus {
  InDevelopment
  Completed
  Maintained
  Archived
}

model Project {
  id          Int            @id @default(autoincrement())
  slug        String         @unique
  title       String
  description String         @db.Text
  techStack   String[]
  featured    Boolean        @default(false)
  repoUrl     String?
  repoVisible Boolean        @default(true)
  demoUrl     String?
  demoVisible Boolean        @default(true)
  order       Int            @default(0)
  startDate   DateTime
  createdAt   DateTime       @default(now())
  images      ProjectImage[]
  status      ProjectStatus  @default(Completed)
}

model ProjectImage {
  id           Int     @id @default(autoincrement())
  projectId    Int
  cloudinaryId String
  url          String
  order        Int     @default(0)
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model SkillGroup {
  id     Int     @id @default(autoincrement())
  name   String
  order  Int     @default(0)
  skills Skill[]
}

model Skill {
  id      Int        @id @default(autoincrement())
  groupId Int
  name    String
  order   Int        @default(0)
  group   SkillGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model Education {
  id                Int     @id @default(autoincrement())
  institution       String
  program           String
  startYear         Int
  endYear           Int?
  gpa               String?
  transcriptUrl     String?
  transcriptVisible Boolean @default(false)
  order             Int     @default(0)
}

model Certification {
  id                Int       @id @default(autoincrement())
  name              String
  issuer            String
  issueDate         DateTime
  expirationDate    DateTime?
  credentialId      String?
  credentialUrl     String?
  credentialVisible Boolean   @default(true)
  order             Int       @default(0)
}

model GalleryItem {
  id           Int     @id @default(autoincrement())
  cloudinaryId String
  url          String
  caption      String?
  order        Int     @default(0)
}
